{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Time by Application",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum by (app) (increase(openrescue_active_seconds_total[1h]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie"
      }
    },
    {
      "title": "Time by Project",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum by (project) (increase(openrescue_active_seconds_total[1h]))",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie"
      }
    },
    {
      "title": "Time by Category",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum by (category) (increase(openrescue_active_seconds_total[1h]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie"
      }
    },
    {
      "title": "Current Idle Time",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "openrescue_idle_seconds",
          "legendFormat": "Idle",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "title": "Daily Productivity Score",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum(increase(openrescue_active_seconds_total{category=\"productive\"}[24h])) / sum(increase(openrescue_active_seconds_total[24h])) * 100",
          "legendFormat": "Productivity %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Activity Timeline",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"openrescue\"} | json",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      }
    }
  ],
