{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Time Logged",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "title": "Productivity Pulse",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "(\n  (sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=\"very_productive\"}[$__range])) * 4\n  + sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=\"productive\"}[$__range])) * 3\n  + sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=\"uncategorized\"}[$__range])) * 2\n  + sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=\"distracting\"}[$__range])) * 1\n  + sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=\"very_distracting\"}[$__range])) * 0)\n  /\n  (sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\"}[$__range])) * 4)\n) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "title": "Category Breakdown",
      "type": "piechart",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum by (category) (increase(openrescue_active_seconds_total{instance=~\"$hostname.*\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "very_productive" }, "properties": [{ "id": "color", "value": { "fixedColor": "#2563a0", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "productive" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5b9bd5", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "uncategorized" }, "properties": [{ "id": "color", "value": { "fixedColor": "#808080", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "distracting" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e8913a", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "very_distracting" }, "properties": [{ "id": "color", "value": { "fixedColor": "#d94040", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "title": "Time by Day",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 18, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "sum by (category) (increase(openrescue_active_seconds_total{instance=~\"$hostname.*\"}[1d]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "barAlignment": 0
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "very_productive" }, "properties": [{ "id": "color", "value": { "fixedColor": "#2563a0", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "productive" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5b9bd5", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "uncategorized" }, "properties": [{ "id": "color", "value": { "fixedColor": "#808080", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "distracting" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e8913a", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "very_distracting" }, "properties": [{ "id": "color", "value": { "fixedColor": "#d94040", "mode": "fixed" } }] }
        ]
      },
      "options": {}
    },
    {
      "title": "Productive Time %",
      "type": "stat",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "(sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=~\"very_productive|productive\"}[$__range])) / sum(increase(openrescue_active_seconds_total{instance=~\"$hostname.*\"}[$__range]))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "title": "Top Applications",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "topk(20, sum by (app, category) (increase(openrescue_active_seconds_total{instance=~\"$hostname.*\"}[$__range])))",
          "legendFormat": "{{app}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "app": "App",
              "category": "Category",
              "Value": "Time"
            }
          }
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "title": "Uncategorized Apps (Triage Queue)",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Mimir" },
      "targets": [
        {
          "expr": "topk(20, sum by (app) (increase(openrescue_active_seconds_total{instance=~\"$hostname.*\", category=\"uncategorized\"}[$__range])))",
          "legendFormat": "{{app}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "title": "Window Titles — Ptyxis",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (window_title, project) (sum_over_time({job=\"openrescue\", hostname=~\"$hostname\", app=~\".*[Pp]tyxis.*\"} | json | unwrap duration_seconds [$__range])) >= 300",
          "legendFormat": "{{project}}: {{window_title}}",
          "refId": "A"
        },
        {
          "expr": "sum(sum by (window_title, project) (sum_over_time({job=\"openrescue\", hostname=~\"$hostname\", app=~\".*[Pp]tyxis.*\"} | json | unwrap duration_seconds [$__range])) < 300)",
          "legendFormat": "Other",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Window Titles — Browser",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (window_title) (sum_over_time({job=\"openrescue\", hostname=~\"$hostname\", app=~\".*(firefox|Chrome|chrom).*\"} | json | unwrap duration_seconds [$__range])) >= 300",
          "legendFormat": "{{window_title}}",
          "refId": "A"
        },
        {
          "expr": "sum(sum by (window_title) (sum_over_time({job=\"openrescue\", hostname=~\"$hostname\", app=~\".*(firefox|Chrome|chrom).*\"} | json | unwrap duration_seconds [$__range])) < 300)",
          "legendFormat": "Other",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Window Titles — Slack",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (window_title) (sum_over_time({job=\"openrescue\", hostname=~\"$hostname\", app=~\".*[Ss]lack.*\"} | json | unwrap duration_seconds [$__range])) >= 300",
          "legendFormat": "{{window_title}}",
          "refId": "A"
        },
        {
          "expr": "sum(sum by (window_title) (sum_over_time({job=\"openrescue\", hostname=~\"$hostname\", app=~\".*[Ss]lack.*\"} | json | unwrap duration_seconds [$__range])) < 300)",
          "legendFormat": "Other",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "title": "Activity Timeline",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"openrescue\", hostname=~\"$hostname\"} | json",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["openrescue"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": { "type": "prometheus", "uid": "Mimir" },
        "definition": "label_values(openrescue_active_seconds_total, instance)",
        "includeAll": true,
        "name": "hostname",
        "label": "Device",
        "query": {
          "qryType": 1,
          "query": "label_values(openrescue_active_seconds_total, instance)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "regex": "/([^:]+).*/",
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now/d",
    "to": "now"
  },
  "timepicker": {
    "hidden": false,
    "quick_ranges": [
      { "display": "Today so far", "from": "now/d", "to": "now" },
      { "display": "This week so far", "from": "now/w", "to": "now" },
      { "display": "This month so far", "from": "now/M", "to": "now" },
      { "display": "This year so far", "from": "now/y", "to": "now" },
      { "display": "All time", "from": "now-10y", "to": "now" }
    ]
  },
  "timezone": "browser",
  "title": "Activity Overview",
  "uid": "openrescue-activity-overview",
  "version": 4
}
